# ============================================================
# Configuration Telegram – DataVortex
# ============================================================
# 1. Allez sur https://my.telegram.org/auth
# 2. Connectez-vous avec votre numéro de téléphone Telegram
# 3. Cliquez sur "API development tools"
# 4. Créez une application et copiez api_id et api_hash ci-dessous

API_ID=18270403
API_HASH=f05b1d4efc121eed61b900ecd08a9255
PHONE=+33769078740

# Nom du fichier de session (la session est sauvegardée localement,
# pas besoin de se reconnecter à chaque lancement)
SESSION_NAME=datavortex_session

# Nombre de messages analysés par channel lors du scan (défaut 200)
SCAN_LIMIT=200

# Clé API Groq – https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# ── Téléchargement parallèle ──────────────────────────────────────────────────
# Nombre de workers parallèles pour le téléchargement (défaut 4)
DOWNLOAD_WORKERS=4
# Taille des chunks en KB (défaut 512)
DOWNLOAD_CHUNK_KB=512

# ── Recherche de credentials ciblés ──────────────────────────────────────────
# Domaines à rechercher dans les fichiers passwords.txt de chaque archive.
# Plusieurs domaines séparés par des virgules.
CREDENTIAL_TARGETS=passculture.app,messervices.etudiant.gouv.fr
